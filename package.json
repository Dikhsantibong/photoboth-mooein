{
  "name": "my-app",
  "version": "0.1.19",
  "private": true,
  "main": "main.js",
  "author": "RoamBooth",
  "description": "RoamBooth Machine Application",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/tasks-vision": "^0.10.35",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "localforage": "^1.10.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.18",
    "react-simple-keyboard": "^3.8.204"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "compression": "maximum",
    "appId": "com.roambooth.machine1",
    "productName": "CTECHBOOTH",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "main.js",
      "preload.js",
      ".next/**/*",
      "!.next/cache/**/*",
      "!.next/cache",
      "!**/*.map",
      "public/**/*",
      ".env",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo/logo.png"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ]
  }
}
